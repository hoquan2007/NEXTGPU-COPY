# Copy this file to .env.local and fill values when needed.
# Do NOT put real secrets in this file. Do NOT commit .env.local.

# --- Milestone 2+ (Clerk Auth) ---
# Lấy từ https://dashboard.clerk.com → Application → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# URL trang auth trong app (Clerk dùng để redirect sau login/signup)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- Milestone 3+ (MongoDB Atlas) ---
# Server-only — NEVER prefix with NEXT_PUBLIC_ (có password DB).
# Atlas → Cluster → Connect → Drivers → copy URI, thay <password>.
# Network Access: Allow Access from Anywhere 0.0.0.0/0 (học tập) hoặc IP máy bạn.
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?appName=mini-nextgpu

# --- Milestone 8+ (Supabase Storage) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
